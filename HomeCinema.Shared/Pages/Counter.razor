@page "/music"
@inject IMediaLibraryService Library
@inject NavigationManager Nav

<PageTitle>Music — HomeCinema</PageTitle>

<div class="library-page">
    @if (_loading)
    {
        <div class="state-view">
            <div class="spinner" aria-label="Loading"></div>
            <p>Scanning library…</p>
        </div>
    }
    else if (!_filtered.Any())
    {
        <div class="state-view">
            <svg class="state-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
            </svg>
            <p>No music found</p>
            <small>@(string.IsNullOrWhiteSpace(_search) ? "Check storage permissions in Settings" : "Try a different search")</small>
        </div>
    }
    else
    {
        <div class="media-list" role="list">
            @foreach (var item in _filtered)
            {
                <button class="media-row" role="listitem" @onclick="() => Open(item)">
                    <div class="media-thumb media-thumb--audio" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                        </svg>
                    </div>
                    <div class="media-info">
                        <span class="media-title">@item.Title</span>
                        <span class="media-meta">@(item.Artist ?? "Unknown Artist") · @item.DurationString</span>
                    </div>
                    <svg class="media-chevron" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
                    </svg>
                </button>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter(Name = "SearchQuery")] private string _search { get; set; } = string.Empty;

    private List<MediaItem> _tracks = new();
    private bool _loading = true;

    private IEnumerable<MediaItem> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _tracks
        : _tracks.Where(t => t.Title.Contains(_search, StringComparison.OrdinalIgnoreCase)
                           || (t.Artist ?? string.Empty).Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _tracks = (await Library.GetAudioAsync()).ToList();
        _loading = false;
    }

    private void Open(MediaItem item) =>
        Nav.NavigateTo($"/audio-player?uri={Uri.EscapeDataString(item.Uri)}&title={Uri.EscapeDataString(item.Title)}");
}
